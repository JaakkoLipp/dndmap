# Project
COMPOSE_PROJECT_NAME=dnd-campaign-map
APP_ENV=development
PERSISTENCE_BACKEND=memory

# Host ports
HTTP_PORT=8080
API_PORT=8000
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Web/API URLs
PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://api:8000

# Postgres. Current API storage is in-memory; hosted mode will use DATABASE_URL.
POSTGRES_DB=dndmap
POSTGRES_USER=dndmap
POSTGRES_PASSWORD=dndmap_dev_password
DATABASE_URL=postgresql+psycopg://dndmap:dndmap_dev_password@postgres:5432/dndmap

# Redis. Hosted mode uses Redis for sessions, presence, pub/sub, jobs, and rate limits.
REDIS_PASSWORD=dndmap_redis_dev_password
REDIS_URL=redis://:dndmap_redis_dev_password@redis:6379/0

# S3-compatible object storage via MinIO. Hosted mode stores uploads and exports here.
MINIO_ROOT_USER=dndmap_minio
MINIO_ROOT_PASSWORD=dndmap_minio_dev_password
S3_BUCKET=dnd-campaign-map
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=dndmap_minio
S3_SECRET_ACCESS_KEY=dndmap_minio_dev_password
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# App secrets
SESSION_SECRET=replace-with-at-least-32-random-characters
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8080

# Planned hosted auth. Current app code may ignore these until auth lands.
AUTH_ENABLED=false
AUTH_OAUTH_PROVIDERS=discord,google,github
OAUTH_REDIRECT_BASE_URL=http://localhost:3000/api/auth/callback
OAUTH_DISCORD_CLIENT_ID=
OAUTH_DISCORD_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Native development examples when running apps outside Docker:
# DATABASE_URL=postgresql+psycopg://dndmap:dndmap_dev_password@localhost:5432/dndmap
# REDIS_URL=redis://:dndmap_redis_dev_password@localhost:6379/0
# S3_ENDPOINT_URL=http://localhost:9000
