# Project
COMPOSE_PROJECT_NAME=dnd-campaign-map
APP_ENV=development
PERSISTENCE_BACKEND=memory

# Host ports
HTTP_PORT=8080
API_PORT=8000
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Web/API URLs
#
# PUBLIC_SITE_URL is the public entry point. The bundled nginx proxy
# fronts both the web app and the API at this URL, so this is where end
# users (and OAuth redirect URIs) point. Update it to your host's
# scheme://host:port — e.g. http://192.0.2.10:8080 or https://maps.example.com.
PUBLIC_SITE_URL=http://localhost:8080
#
# Leave NEXT_PUBLIC_API_BASE_URL UNSET for the bundled Compose stack: the
# web app will make same-origin requests to /api/* which nginx routes to
# the API. Setting it to an absolute URL breaks the OAuth flow (the API
# redirects to /login, which the browser resolves against the API
# origin and 404s). Only set this when the web and API live on
# genuinely different origins behind your own reverse proxy.
# NEXT_PUBLIC_API_BASE_URL=
#
# INTERNAL_API_BASE_URL is the in-network address Next.js uses to proxy
# /api/* in dev/CSR (set automatically by docker-compose).
INTERNAL_API_BASE_URL=http://api:8000

# Postgres
POSTGRES_DB=dndmap
POSTGRES_USER=dndmap
POSTGRES_PASSWORD=dndmap_dev_password
DATABASE_URL=postgresql+asyncpg://dndmap:dndmap_dev_password@postgres:5432/dndmap
PERSISTENCE_BACKEND=postgres

# Redis. Hosted mode uses Redis for sessions, presence, pub/sub, jobs, and rate limits.
# Leave REDIS_URL unset to fall back to an in-process broker (suitable for a
# single API process; required for multi-process realtime fanout).
REDIS_PASSWORD=dndmap_redis_dev_password
REDIS_URL=redis://:dndmap_redis_dev_password@redis:6379/0

# Rate limiting. Recommended ON in production. Falls back to in-memory storage
# when REDIS_URL is unset.
RATE_LIMIT_ENABLED=false

# S3-compatible object storage via MinIO. Hosted mode stores uploads and exports here.
MINIO_ROOT_USER=dndmap_minio
MINIO_ROOT_PASSWORD=dndmap_minio_dev_password
S3_BUCKET=dnd-campaign-map
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=dndmap_minio
S3_SECRET_ACCESS_KEY=dndmap_minio_dev_password
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# App secrets
SESSION_SECRET=replace-with-at-least-32-random-characters
JWT_SECRET=replace-with-at-least-32-random-characters-for-jwt
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8080

# Auth — set AUTH_ENABLED=true to enable login.
# Username login (no password) is available at POST /api/v1/auth/local/login once enabled.
# To also enable OAuth providers, configure the credentials below and register redirect URIs:
#   Discord:  http://localhost:8080/api/v1/auth/discord/callback
#   Google:   http://localhost:8080/api/v1/auth/google/callback
#   GitHub:   http://localhost:8080/api/v1/auth/github/callback
AUTH_ENABLED=false
# Username login (no password). Off by default so production OAuth
# deployments don't accidentally expose a passwordless route. Enable
# only on trusted local networks.
LOCAL_LOGIN_ENABLED=false
OAUTH_REDIRECT_BASE_URL=http://localhost:8080/api/v1/auth
OAUTH_DISCORD_CLIENT_ID=
OAUTH_DISCORD_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Native development examples when running apps outside Docker:
# DATABASE_URL=postgresql+psycopg://dndmap:dndmap_dev_password@localhost:5432/dndmap
# REDIS_URL=redis://:dndmap_redis_dev_password@localhost:6379/0
# S3_ENDPOINT_URL=http://localhost:9000
